{
  "context": {
    "fileName": [
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md"
    ]
  },
  "mcp": {
    "allowed": [
      "tmux-mcp"
    ]
  },
  "mcpServers": {
    "tmux-mcp": {
      "args": [
        "-lc",
        "exec ./scripts/run-tmux-mcp.sh"
      ],
      "command": "bash"
    }
  }
}
